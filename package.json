{
  "name": "stellar-sdk-complete-test",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "test:node": "node --test tests/*.test.ts",
    "test:deno": "deno test --no-check --allow-net --allow-read --allow-env tests/",
    "test:bun": "bun test tests/",
    "test:all": "npm run test:node && npm run test:deno && npm run test:bun",
    "test:pm": "bash scripts/test-pms.sh"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "typescript": "~6.0.3"
  },
  "dependencies": {
    "@stellar/stellar-sdk": "16.0.0"
  }
}
